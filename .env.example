APP_NAME=vision-inference-backend
APP_ENV=local
MODEL_NAME=yolov8n.pt
CONFIDENCE_THRESHOLD=0.25
IMAGE_SIZE=640
MAX_UPLOAD_MB=10
MAX_VIDEO_UPLOAD_MB=200
VIDEO_FRAME_STRIDE=30
MAX_VIDEO_FRAMES=120
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=vision-tasks
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
DATABASE_URL=sqlite:///./vision.db
POSTGRES_DB=vision_backend
POSTGRES_USER=vision
POSTGRES_PASSWORD=vision
